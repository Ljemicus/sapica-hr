{
  "name": "petpark",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "type-check": "tsc --noEmit",
    "db:migrate": "supabase db push",
    "db:diff": "supabase db diff",
    "deploy:staging": "vercel --target=preview",
    "deploy:prod": "vercel --prod",
    "ci": "npm run lint && npm run type-check && npm run test:ci && npm run build",
    "validate:env": "node scripts/validate-env.js",
    "validate:prod": "node scripts/validate-env.js --env .env.prod",
    "check:security": "curl -I http://localhost:3000 2>/dev/null | grep -i \"x-\" || true",
    "check:build": "npm run build && echo \"✅ Build successful\"",
    "preflight": "npm run validate:prod && npm run check:build && npm run lint",
    "launch:check": "npm run preflight && echo \"✅ All pre-launch checks passed\""
  },
  "dependencies": {
